cd ~/Projects/Test_HAL_Blink

cppcheck \
  --enable=all \
  --error-exitcode=1 \
  --suppress=missingIncludeSystem \
  --suppress=unusedFunction \
  --suppress=unmatchedSuppression \
  --suppress=preprocessorErrorDirective \
  --suppress=comparePointers:Cube_Directory/Drivers/CMSIS/Include/cmsis_gcc.h \
  -DSTM32F401xC \
  -DUSE_HAL_DRIVER \
  -D__GNUC__ \
  -D__ARM_ARCH_7EM__ \
  -I Core/Inc \
  -I Cube_Directory/Drivers/STM32F4xx_HAL_Driver/Inc \
  -I Cube_Directory/Drivers/STM32F4xx_HAL_Driver/Inc/Legacy \
  -I Cube_Directory/Drivers/CMSIS/Device/ST/STM32F4xx/Include \
  -I Cube_Directory/Drivers/CMSIS/Include \
  Core/Src/main.c \
  2>&1 | tee cppcheck_report.txt
